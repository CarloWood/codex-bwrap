PROJECTDIR="$HOME/projects/github/codex"
REPOBASE="openai-codex.git"

# Set up a default project environment.
project_environment

# Change default current working directory for Codex.
export CODEX_DIRECTORY="codex-rs"

# Run the debug builds from here.
export BUILDDIR="$REPOROOT/codex-rs/target/debug"
#del_path $HOME/bin
#pre_path $BUILDDIR
#pre_path $HOME/bin

# Required for a Rust project.
export CARGO_HOME=$HOME_CODEX/.cargo
mkdir -p "$CARGO_HOME/bin"
pre_path "$CARGO_HOME/bin"
CODEX_EXTRA_WRITABLE_ROOTS=("${HOME_CODEX}/.cargo" "${HOME_CODEX}/.rustup")

function s()
{
  find $REPOROOT -name target -prune -o -type f -name "*.rs" -print
}

function just()
{
  # Force nightly Rust so rustfmt supports nightly-only options.
  env RUSTUP_TOOLCHAIN=nightly just "$@"
}

function make ()
{
  CURDIR=$(pwd)
  CPUS=`grep '^processor' /proc/cpuinfo | wc --lines`
  RET=0
  not_done=1
  while [ $not_done -eq 1 ]; do
    not_done=0
    case $1 in
    -j)
      shift;
      CPUS=$1
      shift;
      not_done=1
      ;;
    ctags|tags)
      cd $BUILDDIR && ctags --language-force=rust `s`
      gentags $BUILDDIR/tags 2>/dev/null | sort -u > $BUILDDIR/tags.vim
      ;;
    *)
      cd $REPOROOT/codex-rs && cargo build -p codex-cli
      ;;
    esac
  done
  cd $CURDIR
  return $RET
}
