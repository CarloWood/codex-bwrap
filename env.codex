# If this happens there is a problem. Unset CODEX_WORKSPACE then source ~/.bashrc.
test -z "$CODEX_WORKSPACE" || echo "~/projects/env.codex: warning: CODEX_WORKSPACE is part of env.base"

# The "home" directory of codex.
HOME_CODEX="/opt/ext4/nvme2/codex"
# Where to find the global codex configuration.
CODEX_HOME="$HOME/.codex"

codex() {
  # Save the original positional parameters.
  local original_args=("$@")

  (
    # Set positional parameters for the sourced script.
    set -- "${original_args[@]}"

    # Run codex. Note that CODEX_HOME must still be set when running `codex`:
    # this function must be run from an interactive shell.
    source $HOME/projects/github/codex/codex.run
  )
  local exit_code=$?

  # Handle exit codes from the subshell
  if [[ $exit_code -ne 0 ]]; then
    echo "codex.run failed with exit code: $exit_code" >&2
    return $exit_code
  fi
}
